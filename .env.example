# Recall.ai API key
RECALL_API_KEY=

# OpenRouter API key (for LLM)
OPENROUTER_API_KEY=

# ElevenLabs API key and voice IDs (for tts_backend=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Service URL (public URL for webhooks, e.g. https://your-domain.com)
SERVICE_URL=

# TTS backend: "elevenlabs" or "local" (Kokoro+RVC)
GMEET_TTS_BACKEND=elevenlabs

# LLM routing: "simple" (single model) or "voice_gateway" (memory+RAG+routing)
GMEET_LLM_ROUTING=simple

# LLM model (for simple routing)
GMEET_LLM_MODEL=anthropic/claude-sonnet-4

# Voice gateway models (for voice_gateway routing)
GMEET_FAST_MODEL=google/gemini-2.5-flash
GMEET_STANDARD_MODEL=openai/gpt-4.1-mini
GMEET_DEEP_MODEL=anthropic/claude-sonnet-4

# RVC config (for tts_backend=local)
GMEET_RVC_MODEL_PATH=
GMEET_RVC_EXP_DIR=
GMEET_RVC_REPO_DIR=
GMEET_RVC_F0_METHOD=rmvpe
GMEET_RVC_F0_UP_KEY=0
GMEET_RVC_INDEX_RATE=0.0

# Kokoro voice (for tts_backend=local)
GMEET_KOKORO_VOICE=af_heart

# Server port
GMEET_PORT=9120

# Hermes home directory (defaults to ~/.hermes)
GMEET_HERMES_HOME=
